  "patience": 15,
  "gpus": 2,
  "use_tta": false,
  "use_instance_norm": true,
  "find_lr": false,
  "min_delta": 0.0001,
  "use_cache": false,
  "pretrained_path": "scripts/training/outputs/resunet_advanced_pretrained/best_model.pth",
  "freeze_backbone_epochs": 10,
